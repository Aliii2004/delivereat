# ═══════════════════════════════════════════════════════════
#  DeliverEat — Environment Variables
#  Bu faylni .env ga nusxa ko'chiring va qiymatlarni to'ldiring
#  cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ─── JWT (openssl rand -base64 64 bilan generatsiya qiling)
JWT_SECRET=CHANGE_ME_use_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_use_openssl_rand_base64_64_different

# ─── INTERNAL API SECURITY ─────────────────────────────────
# S1 ↔ S2 internal communication uchun shared secret
INTERNAL_API_SECRET=CHANGE_ME_internal_secret_key_here

# ─── DATABASE (ikkalasi ham bir xil user/password ishlatadi)
DB_USER=delivereat_user
DB_PASSWORD=CHANGE_ME_strong_password_here
DB1_NAME=delivereat_main
DB2_NAME=delivereat_analytics

# ─── REDIS
REDIS_PASSWORD=CHANGE_ME_redis_password_here
# REDIS_URL avtomatik quriladi format: redis://:password@host:port
# Docker compose ichida:
# REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ─── SERVER INTERNAL URLS (docker-compose ichida container nomi)
SERVER1_INTERNAL_URL=http://server1:4000
SERVER2_INTERNAL_URL=http://server2:8000

# ─── CLIENT (production da real domain bo'ladi)
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_GRAPHQL_URL=http://localhost/graphql
NEXT_PUBLIC_SOCKET_URL=http://localhost
